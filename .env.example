# Synthetic Data Flywheel - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# OpenRouter Configuration (for data generation)
# =============================================================================
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model to use for generation (Qwen3 8B recommended)
# Available models: https://openrouter.ai/models
OPENROUTER_MODEL=qwen/qwen3-8b:free

# OpenRouter API base URL (optional, defaults to https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# =============================================================================
# Ollama Configuration (for quality judging)
# =============================================================================
# Ollama server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Model to use for quality judging (Gemma4 E2B recommended)
# Must be pulled to your Ollama instance: ollama pull gemma4:4b
OLLAMA_MODEL=gemma4:4b

# =============================================================================
# Quality Thresholds
# =============================================================================
# Minimum overall quality score (0-10 scale)
QUALITY_MIN_SCORE=7.0

# Minimum scores for individual dimensions
QUALITY_MIN_COHERENCE=6.0
QUALITY_MIN_ACCURACY=6.0
QUALITY_MIN_HELPFULNESS=6.0

# =============================================================================
# Flywheel Configuration
# =============================================================================
# Maximum number of cycles to run
MAX_CYCLES=10

# Minimum pass rate to continue to next cycle
MIN_PASS_RATE=0.5

# =============================================================================
# Paths
# =============================================================================
# Data directory for storing datasets
DATA_DIR=./data

# Checkpoint directory for saving/loading cycle state
CHECKPOINT_DIR=./data/checkpoints

# Reports output directory
REPORT_OUTPUT_DIR=./reports

# Notebook output directory
NOTEBOOK_OUTPUT_DIR=./notebooks

# =============================================================================
# HuggingFace Configuration (optional)
# =============================================================================
# HuggingFace API token for dataset uploads
# Get your token from: https://huggingface.co/settings/tokens
# HUGGINGFACE_TOKEN=your_hf_token_here

# =============================================================================
# Training Configuration
# =============================================================================
# Base model for fine-tuning
TRAINER_BASE_MODEL=unsloth/llama-3-8b-bnb-4bit

# =============================================================================
# Generator Settings
# =============================================================================
# Maximum tokens for generation
GENERATOR_MAX_TOKENS=2048

# Temperature for generation (0.0 - 2.0)
GENERATOR_TEMPERATURE=0.7

# Top-p sampling (0.0 - 1.0)
GENERATOR_TOP_P=0.9

# Request timeout in seconds
GENERATOR_TIMEOUT=120

# =============================================================================
# Judge Settings
# =============================================================================
# Maximum tokens for judgment
JUDGE_MAX_TOKENS=1024

# Temperature for judging (lower for consistency)
JUDGE_TEMPERATURE=0.3

# Request timeout in seconds
JUDGE_TIMEOUT=60

# =============================================================================
# A2A Agent Settings
# =============================================================================
# Host for A2A agent server
A2A_HOST=0.0.0.0

# Port for A2A agent server
A2A_PORT=8080

# =============================================================================
# Logging
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json, console
LOG_FORMAT=json
