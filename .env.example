# Synthetic Data Flywheel Configuration

# OpenRouter API Key (for data generation)
OPENROUTER_API_KEY=your_openrouter_api_key

# OpenRouter Model
OPENROUTER_MODEL=qwen/qwen3-8b

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:4b

# Flywheel Configuration
DATA_DIR=./data
CHECKPOINT_DIR=./checkpoints
REPORT_OUTPUT_DIR=./reports
NOTEBOOK_OUTPUT_DIR=./notebooks

# Quality Settings
QUALITY_MIN_SCORE=7.0
MAX_CYCLES=3

# HuggingFace Token (optional, for model downloads)
HUGGINGFACE_TOKEN=
